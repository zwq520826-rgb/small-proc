}
.timeline.data-v-00b5e79f {
  display: flex;
  justify-content: space-between;
  position: relative;
}
.timeline-item.data-v-00b5e79f {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}
.timeline-dot.data-v-00b5e79f {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
