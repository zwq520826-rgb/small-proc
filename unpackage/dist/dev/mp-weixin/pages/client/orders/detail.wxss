}
.timeline-item.active .timeline-dot.data-v-00b5e79f {
  background: #1a73e8;
  box-shadow: 0 0 0 8rpx rgba(26, 115, 232, 0.1);
}
.timeline-item.completed .timeline-dot.data-v-00b5e79f {
  background: #4caf50;
}
.check-icon.data-v-00b5e79f {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}
.timeline-label.data-v-00b5e79f {
  font-size: 24rpx;
  color: #666666;
}
.timeline-item.active .timeline-label.data-v-00b5e79f {
  color: #1a73e8;
  font-weight: 600;
}
.timeline-item.completed .timeline-label.data-v-00b5e79f {
  color: #4caf50;
  font-weight: 600;
}
.timeline-line.data-v-00b5e79f {
  position: absolute;
  top: 24rpx;
  left: 50%;
  width: 100%;
  height: 2rpx;
  background: #e0e0e0;
  z-index: 1;
}
.timeline-item:last-child .timeline-line.data-v-00b5e79f {
  display: none;
}
.timeline-item.completed + .timeline-item .timeline-line.data-v-00b5e79f {
  background: #4caf50;
}

