.btn-primary.data-v-163fccdb { background: #2196f3; color: #fff;
}
.btn-success.data-v-163fccdb { background: #4caf50; color: #fff;
}
.btn-cancel.data-v-163fccdb { background: #f1f3f6; color: #333; border: 1rpx solid #e5e7eb;
}
.cancel-mask.data-v-163fccdb {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 999999 !important; /* 保证弹窗在底部固定栏/其他浮层之上，避免无法点击 */
  pointer-events: auto;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 20rpx;
  box-sizing: border-box;
}
.cancel-modal.data-v-163fccdb {
  width: auto;
  background: #fff;
  border-radius: 16rpx;
  padding: 26rpx;
  box-sizing: border-box;
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: 20rpx;
  top: auto;
  z-index: 1000001;
  pointer-events: auto;
}
.cancel-title.data-v-163fccdb { font-size: 34rpx; font-weight: 700; margin-bottom: 16rpx;
