// 文档教程: https://uniapp.dcloud.net.cn/uniCloud/schema
{
	"bsonType": "object",
	"required": ["order_id", "sender_id", "sender_role", "content", "create_time"],
	"permission": {
		"read": false,
		"create": false,
		"update": false,
		"delete": false
	},
	"indexes": [
		{
			"name": "idx_order_create_time",
			"unique": false,
			"field": [
				{ "name": "order_id", "type": "asc" },
				{ "name": "create_time", "type": "desc" }
			]
		}
	],
	"properties": {
		"_id": {
			"description": "ID，系统自动生成"
		},
		"order_id": {
			"bsonType": "string",
			"description": "订单ID",
			"foreignKey": "orders._id"
		},
		"sender_id": {
			"bsonType": "string",
			"description": "发送者用户ID",
			"foreignKey": "uni-id-users._id"
		},
		"sender_role": {
			"bsonType": "string",
			"description": "发送者角色",
			"enum": ["user", "rider"]
		},
		"content": {
			"bsonType": "string",
			"description": "消息内容"
		},
		"create_time": {
			"bsonType": "timestamp",
			"description": "创建时间",
			"forceDefaultValue": {
				"$env": "now"
			}
		},
		"update_time": {
			"bsonType": "timestamp",
			"description": "更新时间",
			"forceDefaultValue": {
				"$env": "now"
			}
		}
	}
}
