// 文档教程: https://uniapp.dcloud.net.cn/uniCloud/schema
{
	"bsonType": "object",
	"required": ["user_id", "order_id", "last_read_time"],
	"permission": {
		"read": false,
		"create": false,
		"update": false,
		"delete": false
	},
	"indexes": [
		{
			"name": "idx_user_order",
			"unique": true,
			"field": [
				{ "name": "user_id", "type": "asc" },
				{ "name": "order_id", "type": "asc" }
			]
		},
		{
			"name": "idx_order",
			"unique": false,
			"field": [
				{ "name": "order_id", "type": "asc" }
			]
		}
	],
	"properties": {
		"_id": {
			"description": "ID，系统自动生成"
		},
		"user_id": {
			"bsonType": "string",
			"description": "用户ID",
			"foreignKey": "uni-id-users._id"
		},
		"order_id": {
			"bsonType": "string",
			"description": "订单ID",
			"foreignKey": "orders._id"
		},
		"last_read_time": {
			"bsonType": "long",
			"description": "最后已读时间戳（毫秒）"
		},
		"create_time": {
			"bsonType": "long",
			"description": "创建时间",
			"defaultValue": 0
		},
		"update_time": {
			"bsonType": "long",
			"description": "更新时间",
			"defaultValue": 0
		}
	}
}
