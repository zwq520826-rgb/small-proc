{
	"bsonType": "object",
	"required": ["username", "password_salt", "password_hash"],
	"permission": {
		"read": false,
		"create": false,
		"update": false,
		"delete": false
	},
	"indexes": [
		{
			"name": "idx_username_unique",
			"unique": true,
			"field": [{ "name": "username", "type": "asc" }]
		},
		{
			"name": "idx_create_time",
			"unique": false,
			"field": [{ "name": "create_time", "type": "desc" }]
		}
	],
	"properties": {
		"_id": {},
		"username": {
			"bsonType": "string",
			"description": "登录用户名（小写存储）",
			"title": "用户名"
		},
		"password": {
			"bsonType": "string",
			"description": "兼容历史明文字段（已弃用，新增账号写空）",
			"title": "密码"
		},
		"password_salt": {
			"bsonType": "string",
			"description": "密码盐（随机）",
			"title": "密码盐"
		},
		"password_hash": {
			"bsonType": "string",
			"description": "HMAC-SHA256(password, salt) 十六进制",
			"title": "密码哈希"
		},
		"is_super_admin": { "bsonType": "bool", "title": "是否超级管理员" },
		"remark": { "bsonType": "string", "title": "备注" },
		"enabled": { "bsonType": "bool", "title": "启用" },
		"last_login_date": { "bsonType": "timestamp", "title": "最后登录时间" },
		"last_login_ip": { "bsonType": "string", "title": "最后登录IP" },
		"create_time": { "bsonType": "timestamp", "title": "创建时间" },
		"update_time": { "bsonType": "timestamp", "title": "更新时间" }
	}
}
