{
	"bsonType": "object",
	"required": ["user_id", "type", "status", "price"],
	"permission": {
		"read": "doc.user_id == auth.uid || doc.rider_id == auth.uid",
		"create": "auth.uid != null",
		"update": "doc.user_id == auth.uid || doc.rider_id == auth.uid",
		"delete": "doc.user_id == auth.uid"
	},
	"indexes": [
		{
			"name": "idx_hall_distance",
			"unique": false,
			"field": [
				{
					"name": "status",
					"type": "asc"
				},
				{
					"name": "pay_status",
					"type": "asc"
				},
				{
					"name": "hall_visible",
					"type": "asc"
				},
				{
					"name": "rider_id",
					"type": "asc"
				},
				{
					"name": "pickup_distance",
					"type": "asc"
				},
				{
					"name": "create_time",
					"type": "desc"
				}
			]
		},
		{
			"name": "idx_hall_price",
			"unique": false,
			"field": [
				{
					"name": "status",
					"type": "asc"
				},
				{
					"name": "pay_status",
					"type": "asc"
				},
				{
					"name": "hall_visible",
					"type": "asc"
				},
				{
					"name": "rider_id",
					"type": "asc"
				},
				{
					"name": "price",
					"type": "desc"
				},
				{
					"name": "create_time",
					"type": "desc"
				}
			]
		},
		{
			"name": "idx_rider_status_accept_time",
			"unique": false,
			"field": [
				{
					"name": "rider_id",
					"type": "asc"
				},
				{
					"name": "status",
					"type": "asc"
				},
				{
					"name": "accept_time",
					"type": "desc"
				}
			]
		},
		{
			"name": "idx_user_status_create_time",
			"unique": false,
			"field": [
				{
					"name": "user_id",
					"type": "asc"
				},
				{
					"name": "status",
					"type": "asc"
				},
				{
					"name": "create_time",
					"type": "desc"
				}
			]
		},
		{
			"name": "idx_create_time",
			"unique": false,
			"field": [
				{
					"name": "create_time",
					"type": "desc"
				}
			]
		},
		{
			"name": "idx_pay_status_create_time",
			"unique": false,
			"field": [
				{
					"name": "pay_status",
					"type": "asc"
				},
				{
					"name": "create_time",
					"type": "desc"
				}
			]
		},
		{
			"name": "idx_rider_complete_time",
			"unique": false,
			"field": [
				{
					"name": "rider_id",
					"type": "asc"
				},
				{
					"name": "status",
					"type": "asc"
				},
				{
					"name": "complete_time",
					"type": "desc"
				}
			]
		}
	],
	"properties": {
		"_id": {
			"description": "订单ID，系统自动生成"
		},
		"order_no": {
			"bsonType": "string",
			"description": "订单号（YYYYMMDDHHmmss+4位随机数）",
			"title": "订单号"
		},
		"user_id": {
			"bsonType": "string",
			"description": "下单用户ID",
			"foreignKey": "uni-id-users._id",
			"title": "用户ID"
		},
		"rider_id": {
			"bsonType": "string",
			"description": "接单骑手ID（可选）",
			"foreignKey": "uni-id-users._id",
			"title": "骑手ID"
		},
		"type": {
			"bsonType": "string",
			"description": "订单类型",
			"enum": ["pickup", "errand", "post", "print"],
			"enumDesc": {
				"pickup": "快递代取",
				"errand": "跑腿服务",
				"post": "帮我寄件",
				"print": "打印服务"
			},
			"title": "订单类型"
		},
		"type_label": {
			"bsonType": "string",
			"description": "订单类型标签",
			"title": "类型标签"
		},
		"status": {
			"bsonType": "string",
			"description": "订单状态",
			"enum": ["pending_pay", "pending_accept", "pending_pickup", "delivering", "completed", "cancelled", "abnormal"],
			"enumDesc": {
				"pending_pay": "待支付",
				"pending_accept": "待接单",
				"pending_pickup": "待取货",
				"delivering": "配送中",
				"completed": "已完成",
				"cancelled": "已取消",
				"abnormal": "异常单"
			},
			"title": "订单状态"
		},
		"abnormal_reason": {
			"bsonType": "string",
			"description": "异常原因类型",
			"title": "异常原因"
		},
		"abnormal_remark": {
			"bsonType": "string",
			"description": "异常备注说明",
			"title": "异常备注"
		},
		"abnormal_time": {
			"bsonType": "timestamp",
			"description": "异常触发时间",
			"title": "异常时间"
		},
		"photo_feedback_count": {
			"bsonType": "int",
			"description": "送达照片反馈次数",
			"title": "反馈次数"
		},
		"need_customer_service": {
			"bsonType": "bool",
			"description": "是否需要客服介入",
			"title": "客服介入"
		},
		"pay_method": {
			"bsonType": "string",
			"description": "支付方式",
			"enum": ["balance", "wechat"],
			"title": "支付方式"
		},
		"pay_status": {
			"bsonType": "string",
			"description": "支付状态",
			"enum": ["unpaid", "paid"],
			"title": "支付状态"
		},
		"pay_time": {
			"bsonType": "timestamp",
			"description": "支付完成时间",
			"title": "支付时间"
		},
		"hall_visible": {
			"bsonType": "bool",
			"description": "是否在骑手大厅可见（支付成功后才可见）",
			"title": "大厅可见"
		},
		"out_trade_no": {
			"bsonType": "string",
			"description": "微信商户订单号（out_trade_no）",
			"title": "微信商户单号"
		},
		"refund_status": {
			"bsonType": "string",
			"description": "退款状态",
			"enum": ["none", "refunded_to_balance", "refunding_wechat", "refunded_to_wechat", "refund_failed"],
			"title": "退款状态"
		},
		"refund_time": {
			"bsonType": "timestamp",
			"description": "退款时间",
			"title": "退款时间"
		},
		"price": {
			"bsonType": "double",
			"description": "订单金额",
			"minimum": 0,
			"title": "订单金额"
		},
		"pickup_location": {
			"bsonType": "string",
			"description": "取件地址",
			"title": "取件地址"
		},
		"delivery_location": {
			"bsonType": "string",
			"description": "送达地址",
			"title": "送达地址"
		},
		"address": {
			"bsonType": "string",
			"description": "收货地址（兼容字段）",
			"title": "收货地址"
		},
		"content": {
			"bsonType": "object",
			"description": "订单内容详情",
			"properties": {
				"description": {
					"bsonType": "string",
					"description": "订单描述"
				},
				"images": {
					"bsonType": "array",
					"description": "图片URL数组",
					"items": {
						"bsonType": "string"
					}
				},
				"phone": {
					"bsonType": "string",
					"description": "联系电话"
				},
				"pickup_images": {
					"bsonType": "array",
					"description": "取件凭证图片",
					"items": {
						"bsonType": "string"
					}
				},
				"delivery_images": {
					"bsonType": "array",
					"description": "送达凭证图片",
					"items": {
						"bsonType": "string"
					}
				},
				"runner_fee": {
					"bsonType": "double",
					"description": "跑腿费"
				},
				"is_urgent": {
					"bsonType": "bool",
					"description": "是否加急"
				},
				"is_delivery": {
					"bsonType": "bool",
					"description": "是否送货上门"
				},
				"dorm_number": {
					"bsonType": "string",
					"description": "寝室号"
				}
			},
			"title": "订单内容"
		},
		"tags": {
			"bsonType": "array",
			"description": "订单标签",
			"items": {
				"bsonType": "string"
			},
			"title": "标签"
		},
		"pickup_distance": {
			"bsonType": "double",
			"description": "取件距离（公里）",
			"title": "取件距离"
		},
		"create_time": {
			"bsonType": "timestamp",
			"description": "创建时间",
			"forceDefaultValue": {
				"$env": "now"
			},
			"title": "创建时间"
		},
		"accept_time": {
			"bsonType": "timestamp",
			"description": "接单时间",
			"title": "接单时间"
		},
		"pickup_time": {
			"bsonType": "timestamp",
			"description": "取货时间",
			"title": "取货时间"
		},
		"complete_time": {
			"bsonType": "timestamp",
			"description": "完成时间",
			"title": "完成时间"
		}
	}
}
